{
  "name": "streetlourd-sync",
  "version": "1.0.0",
  "description": "Local sync utility for StreetLourd Clash of Clans dashboard",
  "main": "sync.js",
  "scripts": {
    "sync": "node sync.js",
    "build:css": "tailwindcss -i css/input.css -o css/styles.css --minify",
    "watch:css": "tailwindcss -i css/input.css -o css/styles.css --watch",
    "build:js": "esbuild js/app.js --bundle --minify --outfile=js/bundle.js --format=esm --external:https://www.gstatic.com/*",
    "build": "npm run build:css && npm run build:js"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "firebase-admin": "^11.8.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.3.1"
  }
}
